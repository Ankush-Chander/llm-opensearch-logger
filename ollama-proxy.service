[Unit]
Description=Ollama traffic logging reverse proxy
After=network.target docker.service ollama.service
Wants=docker.service
Requires=ollama.service

[Service]
Type=simple

# --- Adjust these paths to match your installation ---
ExecStart=%h/.local/ollama-proxy/venv/bin/python %h/.local/ollama-proxy/ollama_proxy.py
WorkingDirectory=%h/.local/ollama-proxy

# Environment overrides (edit as needed)
Environment=PROXY_HOST=0.0.0.0
# For multiple backends, use PROXY_MAPPINGS instead of PROXY_PORT/OLLAMA_PORT
# Format: "listen_port:upstream_port[:name]" or "listen_port:host:upstream_port[:name]"
# Environment=PROXY_MAPPINGS=11434:11435:ollama,8002:8003:llama-server
Environment=PROXY_PORT=11434
Environment=OLLAMA_HOST=127.0.0.1
Environment=OLLAMA_PORT=11435
Environment=OPENSEARCH_URL=http://localhost:9200
Environment=OPENSEARCH_INDEX=ollama-traffic
Environment=LOG_BODY_MAX_BYTES=65536

Restart=on-failure
RestartSec=5

# Give Ollama time to start before the proxy attempts connections
ExecStartPre=/bin/sleep 3

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ollama-proxy

[Install]
WantedBy=default.target
